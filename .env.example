# Firebase Web App Config
# Firebase Console > Project Settings > Your apps > Web app > firebaseConfig
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# App Configuration
# Set to false to use real Firebase (true = demo mode with sample data)
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_ADMIN_MASTER_KEY=

# Notion API & Databases (currently unused)
NOTION_API_KEY=
NOTION_DATABASE_ID=
NOTION_RANKING_DB_ID=
NOTION_SCAN_LOG_DB_ID=
PERSONAL_BACKUP_DB_ID=
PERSONAL_STATS_DB_ID=

# Google AI (Gemini) - optional
GOOGLE_GENAI_API_KEY=
